# ─── UniFi OS console / Protect NVR (required) ────────────────────────────
# Base URL of the UniFi OS console running Protect (self-signed cert OK).
UNIFI_HOST=https://your-nvr.local
# LOCAL admin account — Ubiquiti cloud SSO accounts will NOT authenticate here.
UNIFI_USER=local-admin
UNIFI_PASSWORD=change-me
# Verify the console's TLS cert (it's self-signed, so usually false).
VERIFY_SSL=false

# ─── Viewport (required: one of these) ────────────────────────────────────
# Viewport name(s) as they appear in Protect; resolved to viewer ids.
# Comma-separate to drive multiple viewports together (all show the same view).
VIEWPORT_NAME=Living Room Viewport
# Or pin viewer id(s) explicitly (comma-separated); added on top of VIEWPORT_NAME.
# VIEWER_ID=

# ─── Views to expose as HomeKit switches (optional) ───────────────────────
# Comma-separated subset/order of Live View names to expose, one switch each.
# Empty = expose every Live View found in Protect.
# VIEWS=Front Yard,Backyard,Driveway,All Cameras

# ─── Standard server / logging block ──────────────────────────────────────
# Port the service listens on (viewport=8686, govee=8585, sprinkler=8383,
# trimlight=8484; this selector defaults to 8787).
HTTP_PORT=8787
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Log file inside the container (mapped to ./logs/ on the host); empty disables.
LOG_FILE=/app/logs/service.log

# ─── HomeKit selector switches ────────────────────────────────────────────
# Optional bearer token guarding /select/on, /select/off, /select/state. Must
# match the Authorization header in the Homebridge accessory; empty = no auth.
SELECT_TOKEN=
# Seconds to cache the Protect bootstrap that backs /select/state, so the N
# polling switch tiles share one request instead of hammering the NVR.
STATE_CACHE_TTL=2
